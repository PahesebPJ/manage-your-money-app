{
  "expo": {
    "name": "Manage your money",
    "slug": "manage-your-money-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080D12"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moneyapp.capitalmanager"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080D12"
      },
      "package": "com.moneyapp.capitalmanager",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00E5B0",
          "defaultChannel": "subscriptions"
        }
      ]
    ]
  }
}